{
  "manifest_version": 3,
  "name": "Flipshope PriceComparision",
  "version": "2.0",
  "description": "Finds the exact product you're looking at on other e-commerce stores using background tabs.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.amazon.in/*",
    "http://localhost:5000/*",
    "*://*.flipkart.com/*",
    "*://*.croma.com/*",
    "*://*.reliancedigital.in/*",
    "https://team.flipshope.com/*",
    "https://teamdev.flipshope.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "content_scripts": [
    {
      "matches": [
        "*://*.flipkart.com/*"
      ],
      "js": ["blocker.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.amazon.in/*", 
        "*://*.amazon.com/*", 
        "*://*.flipkart.com/*",
        "*://*.croma.com/*",
        "*://*.reliancedigital.in/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
