{
  "manifest_version": 3,
  "name": "Flipshope PriceComparision",
  "version": "2.0",
  "description": "Finds the exact product you're looking at on other e-commerce stores using background tabs.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.amazon.in/*",
    "*://*.flipkart.com/*",
    "*://*.croma.com/*",
    "*://*.reliancedigital.in/*",
    "https://team.flipshope.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.in/*", 
        "*://*.amazon.com/*", 
        "*://*.flipkart.com/*",
        "*://*.croma.com/*",
        "*://*.reliancedigital.in/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}
